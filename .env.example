# MVR Crime Bulletin Scraper Configuration

# Database
DATABASE_URL=sqlite:///./mvr_bulletins.db

# Jina AI API (for web scraping) - Get free key at https://jina.ai/reader/
JINA_API_KEY=your_jina_api_key_here

# OpenRouter API (for LLM extraction) - Get free key at https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Logging
LOG_LEVEL=INFO

# Scraping
SCRAPE_DELAY_SECONDS=2.0
MAX_RETRIES=3
REQUEST_TIMEOUT_SECONDS=30

# LLM Extraction - use "openrouter/free" for auto-routing to free models
LLM_MODEL=openrouter/free

# Bulletin Index URL
BULLETIN_INDEX_URL=https://mvr.gov.mk/mk-MK/odnosi-so-javnost/dnevni-bilteni
BULLETIN_URL_PATTERN=https://mvr.gov.mk/mk-MK/odnosi-so-javnost/dnevni-bilteni/izvadok-na-del-od-dnevnite-nastani-
